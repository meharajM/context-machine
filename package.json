{
  "name": "@mhrj/contextengine-mcp",
  "version": "0.1.2",
  "description": "Team Project Memory skill for shared project knowledge graphs across developer teams, AI coding agents, and multi-agent swarms, plus the optional ContextEngine MCP server",
  "homepage": "https://github.com/meharajM/context-machine#readme",
  "repository": {
    "type": "git",
    "url": "git+https://github.com/meharajM/context-machine.git"
  },
  "bugs": {
    "url": "https://github.com/meharajM/context-machine/issues"
  },
  "type": "module",
  "main": "build/index.js",
  "files": [
    "build",
    "README.md",
    "server.json",
    "skills",
    "plugins",
    ".agents",
    ".contextengine.example.json",
    ".env.example"
  ],
  "bin": {
    "contextengine-mcp": "build/index.js"
  },
  "scripts": {
    "build": "tsc",
    "dev": "tsx watch src/index.ts",
    "lint": "tsc -p tsconfig.typecheck.json",
    "smoke:mcp": "tsx scripts/mcp-smoke.ts",
    "smoke:package": "tsx scripts/package-smoke.ts",
    "smoke:protocol": "tsx scripts/mcp-protocol-smoke.ts",
    "smoke:gdrive": "tsx scripts/gdrive-live-smoke.ts",
    "start": "node build/index.js",
    "test": "vitest run",
    "test:integration": "vitest run src/__tests__/mcp-integration.test.ts src/__tests__/mcp-protocol.test.ts src/__tests__/concurrency.test.ts",
    "test:watch": "vitest",
    "test:coverage": "vitest run --coverage",
    "verify": "npm run lint && npm test && npm run build && npm run smoke:mcp && npm run smoke:protocol && npm run smoke:package",
    "prepublishOnly": "npm run build"
  },
  "publishConfig": {
    "access": "public"
  },
  "keywords": [
    "mcp",
    "context",
    "ai-agents",
    "memory",
    "local-first",
    "team-memory",
    "project-memory",
    "shared-memory",
    "agent-memory",
    "swarm-memory",
    "ai-swarm-memory",
    "multi-agent-memory",
    "multi-agent-collaboration",
    "agent-swarms",
    "agent-swarm",
    "swarm-coordination",
    "developer-team-memory",
    "team-knowledge-graph",
    "project-knowledge-graph",
    "ai-memory",
    "agent-skills",
    "ai-agent-skills",
    "skills",
    "skills-sh",
    "knowledge-base",
    "agent-knowledge-base",
    "shared-knowledge-graph",
    "codex-plugin",
    "codex",
    "claude-code",
    "cursor",
    "copilot",
    "devin",
    "cline",
    "debugging",
    "debugging-history",
    "failed-attempts",
    "solved-bugs",
    "repo-learnings",
    "repo-context",
    "shared-context",
    "developer-productivity"
  ],
  "author": "mhrj",
  "license": "MIT",
  "engines": {
    "node": ">=18"
  },
  "dependencies": {
    "@modelcontextprotocol/sdk": "^1.29.0",
    "diff": "^9.0.0",
    "proper-lockfile": "^4.1.2",
    "gray-matter": "^4.0.3",
    "zod": "^4.3.6",
    "googleapis": "^148.0.0"
  },
  "devDependencies": {
    "@types/node": "^22.0.0",
    "@vitest/coverage-v8": "^3.0.0",
    "tsx": "^4.0.0",
    "typescript": "^5.7.0",
    "vitest": "^3.0.0"
  }
}
